# Пример конфигурационного файла для приложения LangGraph Academy
# Скопируйте этот файл как .env и подставьте ваши значения

# Ваш ключ API от OpenRouter для работы интерактивного генератора Экзамена (Урок 19)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Модель по умолчанию, которая будет выбрана из динамического списка при запуске
OPENROUTER_DEFAULT_MODEL=z-ai/glm-4.5-air:free
